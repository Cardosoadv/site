{
    "name": "cardosoadv/site",
    "version": "3.7.3",
    "description": "Site Institucional e Painel Administrativo",
    "license": "MIT",
    "type": "project",
    "homepage": "https://cardosoebruno.adv.br",
    "authors": [
        {
            "name": "Cognitio Tecnologia",
            "homepage": "https://cognitiotecnologia.com.br"
        }
    ],
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.0",
        "codeigniter4/shield": "^1.2",
        "ezyang/htmlpurifier": "^4.19"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
